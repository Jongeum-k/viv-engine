# docker-compose.yml.example

services:
  postgres:
    image: postgres:17
    container_name: viv-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: {username}
      POSTGRES_PASSWORD: {password}
      POSTGRES_DB: viv_db
    ports:
      - "5432:5432"
    volumes:
      - viv_postgres_data:/var/lib/postgresql/data

  redis:
    image: redis:8
    container_name: viv-redis
    restart: unless-stopped
    ports:
      - "6379:6379"

volumes:
  viv_postgres_data: